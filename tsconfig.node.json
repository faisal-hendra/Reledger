{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/common/**/*",
    "src/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@main/*": ["./src/main/*"],
      "@common/*": ["./src/common/*"],
      "@renderer/*": ["./src/renderer/src/*"],
      "@/*": ["./src/renderer/src/*"]
    },
    "moduleResolution": "bundler",
    "lib": ["es5", "es6", "dom", "dom.iterable"]
  }
}
