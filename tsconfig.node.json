{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/db/**/*.ts",
    "src/**/*",
    "src/types/global.d.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/renderer/src/*"
      ],
      "@": [
        "./src/renderer/src/*"
      ],
      "@renderer": [
        "./src/renderer/src/*"
      ]
    },
    "moduleResolution": "bundler",
    "lib": [
      "es5",
      "es6",
      "dom",
      "dom.iterable"
    ]
  },
}
