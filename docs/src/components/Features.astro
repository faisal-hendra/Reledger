---
interface Feature {
    title: string;
    description: string;
}

const features: Feature[] = [
    {
        title: "Financial Dashboard",
        description:
            "Get a clear overview of your total balance, income, and expenses with interactive charts and month-over-month comparisons.",
    },
    {
        title: "Transaction Management",
        description:
            "Full CRUD operations for income and expenses with predefined categories, advanced filtering, and sortable data tables.",
    },
    {
        title: "100% Local & Private",
        description:
            "Your financial data stays on your device. Built with SQLite for lightweight, offline-first storage with no cloud dependencies.",
    },
    {
        title: "CSV Export",
        description:
            "Export your transaction history to CSV format. Filter by date range or export your full dataset.",
    },
];
---

<section class="features">
    <div class="features-container">
        <h2 class="features-heading">Features</h2>
        <p class="features-subheading">
            Everything you need to track your personal finances
        </p>

        <div class="features-grid">
            {
                features.map((feature, index) => (
                    <article
                        class="feature-card"
                        style={`--delay: ${index * 0.1}s`}
                    >
                        <div class="feature-number">
                            {String(index + 1).padStart(2, "0")}
                        </div>
                        <h3 class="feature-title">{feature.title}</h3>
                        <p class="feature-description">{feature.description}</p>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<style>
    .features {
        padding: 6rem var(--space-xl);
        background: var(--bg-elevated);
        position: relative;
    }

    .features-container {
        max-width: 1100px;
        margin: 0 auto;
    }

    .features-heading {
        font-family: "Playfair Display", serif;
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 600;
        color: var(--text-primary);
        margin: 0 0 var(--space-sm);
        text-align: center;
        letter-spacing: -0.02em;
    }

    .features-subheading {
        font-family: var(--font-body);
        font-size: 1rem;
        color: var(--text-secondary);
        margin: 0 0 var(--space-2xl);
        text-align: center;
        line-height: 1.5;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: var(--space-lg);
    }

    .feature-card {
        position: relative;
        padding: var(--space-xl);
        background: var(--bg-card);
        border: 1px solid var(--border-subtle);
        border-radius: 10px;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) backwards;
        animation-delay: var(--delay);
    }

    .feature-card:hover {
        transform: translateY(-3px);
        border-color: var(--border);
        box-shadow: 0 12px 32px -8px rgba(0, 0, 0, 0.25);
    }

    .feature-number {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.6875rem;
        font-weight: 500;
        color: var(--text-muted);
        margin-bottom: var(--space-lg);
        letter-spacing: 0.12em;
    }

    .feature-title {
        font-family: var(--font-body);
        font-size: 1.0625rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 0 0 var(--space-sm);
        letter-spacing: -0.01em;
    }

    .feature-description {
        font-family: var(--font-body);
        font-size: 0.875rem;
        font-weight: 400;
        color: var(--text-secondary);
        margin: 0;
        line-height: 1.6;
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 768px) {
        .features {
            padding: 4rem var(--space-md);
        }

        .features-grid {
            gap: var(--space-md);
        }

        .feature-card {
            padding: var(--space-lg);
        }
    }
</style>
