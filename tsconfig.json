{
  "files": [],
  "references": [
    {
      "path": "./tsconfig.node.json"
    },
    {
      "path": "./tsconfig.web.json"
    }
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/renderer/src/*"
      ],
      "@": [
        "./src/renderer/src/*"
      ],
      "@renderer": [
        "./src/renderer/src/*"
      ]
    },
    "lib": [
      "es5",
      "es6",
      "dom",
      "dom.iterable"
    ]
  },
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/db/**/*.ts",
    "src/**/*",
    "src/types/global.d.ts"
  ],
}
